#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

struct Node
{
    int vertex;
    Node* next;
};

const int MAX = 10;

int maze[MAX][MAX];
int vertexNo[MAX][MAX];

Node* adjacencyList[100];

int rows, cols;
int vertices = 0;

Node* createNode(int vertex)
{
    Node* temp = new Node;

    temp->vertex = vertex;
    temp->next = NULL;

    return temp;
}

void initializeGraph()
{
    for(int i=0;i<100;i++)
    {
        adjacencyList[i]=NULL;
    }
}

void generateMaze()
{
    srand(time(0));

    for(int i=0;i<rows;i++)
    {
        for(int j=0;j<cols;j++)
        {
            maze[i][j]=rand()%2;
        }
    }

    maze[0][0]=0;
    maze[rows-1][cols-1]=0;
}

void displayMaze()
{
    cout<<"\nMaze\n\n";

    for(int i=0;i<rows;i++)
    {
        for(int j=0;j<cols;j++)
        {
            cout<<maze[i][j]<<" ";
        }

        cout<<endl;
    }
}

void assignVertices()
{
    vertices=0;

    for(int i=0;i<rows;i++)
    {
        for(int j=0;j<cols;j++)
        {
            if(maze[i][j]==0)
            {
                vertexNo[i][j]=vertices;
                vertices++;
            }
            else
            {
                vertexNo[i][j]=-1;
            }
        }
    }
}

void addEdge(int source,int destination)
{
    Node* temp=createNode(destination);

    temp->next=adjacencyList[source];
    adjacencyList[source]=temp;
}

void createGraph()
{
    int dx[8]={-1,-1,-1,0,0,1,1,1};
    int dy[8]={-1,0,1,-1,1,-1,0,1};

    for(int i=0;i<rows;i++)
    {
        for(int j=0;j<cols;j++)
        {
            if(maze[i][j]==0)
            {
                int source=vertexNo[i][j];

                for(int k=0;k<8;k++)
                {
                    int x=i+dx[k];
                    int y=j+dy[k];

                    if(x>=0 && x<rows && y>=0 && y<cols)
                    {
                        if(maze[x][y]==0)
                        {
                            int destination=vertexNo[x][y];
                            addEdge(source,destination);
                        }
                    }
                }
            }
        }
    }
}

void displayAdjacencyList()
{
    cout<<"\nAdjacency List\n\n";

    for(int i=0;i<vertices;i++)
    {
        cout<<i<<" -> ";

        Node* temp=adjacencyList[i];

        while(temp!=NULL)
        {
            cout<<temp->vertex<<" -> ";
            temp=temp->next;
        }

        cout<<"NULL"<<endl;
    }
}
int visited[100];
int parent[100];

void resetVisited()
{
    for(int i=0;i<vertices;i++)
    {
        visited[i]=0;
        parent[i]=-1;
    }
}

void BFS(int start)
{
    int queue[100];

    int front=0;
    int rear=0;

    resetVisited();

    queue[rear++]=start;
    visited[start]=1;

    while(front<rear)
    {
        int current=queue[front++];

        Node* temp=adjacencyList[current];

        while(temp!=NULL)
        {
            int next=temp->vertex;

            if(visited[next]==0)
            {
                visited[next]=1;
                parent[next]=current;
                queue[rear++]=next;
            }

            temp=temp->next;
        }
    }
}

void printPath(int start,int end)
{
    if(visited[end]==0)
    {
        cout<<"\nNo Path Found\n";
        return;
    }

    int path[100];
    int count=0;

    int current=end;

    while(current!=-1)
    {
        path[count++]=current;
        current=parent[current];
    }

    cout<<"\nPath:\n";

    for(int i=count-1;i>=0;i--)
    {
        for(int r=0;r<rows;r++)
        {
            for(int c=0;c<cols;c++)
            {
                if(vertexNo[r][c]==path[i])
                {
                    cout<<"("<<r<<","<<c<<") ";

                    if(i!=0)
                        cout<<"-> ";
                }
            }
        }
    }

    cout<<endl;
}
int main()
{
    cout << "Enter Number of Rows: ";
    cin >> rows;

    cout << "Enter Number of Columns: ";
    cin >> cols;

    initializeGraph();

    generateMaze();

    displayMaze();

    assignVertices();

    createGraph();

    displayAdjacencyList();

    int start = vertexNo[0][0];
    int end = vertexNo[rows-1][cols-1];

    if(start == -1 || end == -1)
    {
        cout << "\nNo Path Exists\n";
        return 0;
    }

    BFS(start);

    printPath(start, end);

    return 0;
}