#include<iostream>
#include<stdio.h>
using namespace std;

struct node
{
    int data;
    node* prev;
    node* next;
};

node* list = NULL;

void insert(int value)
{
    node* temp;
    temp = (node*)malloc(sizeof(node));

    temp->data = value;
    temp->next = NULL;
    temp->prev = NULL;

    if(list == NULL)
    {
        list = temp;
        return;
    }

    node* cur = list;

    while(cur->next != NULL)
    {
        cur = cur->next;
    }

    cur->next = temp;
    temp->prev = cur;
}

void display()
{
    if(list == NULL)
    {
        cout << "List is Empty\n";
        return;
    }

    node* cur = list;

    while(cur != NULL)
    {
        cout << cur->data << " ";
        cur = cur->next;
    }

    cout << endl;
}

void reverseList()
{
    if(list == NULL)
    {
        cout << "List is Empty\n";
        return;
    }

    node* cur = list;
    node* temp = NULL;

    while(cur != NULL)
    {
        temp = cur->prev;
        cur->prev = cur->next;
        cur->next = temp;

        cur = cur->prev;
    }

    if(temp != NULL)
    {
        list = temp->prev;
    }

    cout << "List Reversed Successfully\n";
}

void findMinimum()
{
    if(list == NULL)
    {
        cout << "List is Empty\n";
        return;
    }

    node* cur = list;
    int minimum = cur->data;

    while(cur != NULL)
    {
        if(cur->data < minimum)
            minimum = cur->data;

        cur = cur->next;
    }

    cout << "Minimum Element = " << minimum << endl;
}

void findMaximum()
{
    if(list == NULL)
    {
        cout << "List is Empty\n";
        return;
    }

    node* cur = list;
    int maximum = cur->data;

    while(cur != NULL)
    {
        if(cur->data > maximum)
            maximum = cur->data;

        cur = cur->next;
    }

    cout << "Maximum Element = " << maximum << endl;
}

int main()
{
    while(true)
    {
        int choice, value;

        cout << "\n===== DOUBLY LINKED LIST =====\n";
        cout << "1. Insert\n";
        cout << "2. Print List\n";
        cout << "3. Reverse List\n";
        cout << "4. Find Minimum\n";
        cout << "5. Find Maximum\n";
        cout << "6. Exit\n";

        cout << "Enter Choice: ";
        cin >> choice;

        if(choice == 1)
        {
            cout << "Enter Value: ";
            cin >> value;
            insert(value);
        }

        if(choice == 2)
        {
            display();
        }

        if(choice == 3)
        {
            reverseList();
        }

        if(choice == 4)
        {
            findMinimum();
        }

        if(choice == 5)
        {
            findMaximum();
        }

        if(choice == 6)
        {
            break;
        }
    }

    return 0;
}